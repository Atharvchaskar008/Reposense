# ── Primary LLM (recommended for hackathon) ─────────────────────────────
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V3-0324

# ── Fallback LLM providers ──────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Runtime ─────────────────────────────────────────────────────────────
EXECUTION_MODE=autonomous
LOW_COST_MODE=false
USE_LOCAL_MODELS=false
LOCAL_MODEL=deepseek-coder
OLLAMA_BASE_URL=http://localhost:11434

# ── Server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60

# ── Git clone ───────────────────────────────────────────────────────────
GIT_CLONE_TIMEOUT=180

# ── Model routing (legacy labels) ───────────────────────────────────────
FIX_AGENT_MODEL=featherless
EXPLANATION_AGENT_MODEL=featherless
SECURITY_AGENT_MODEL=featherless
IMPACT_AGENT_MODEL=featherless
